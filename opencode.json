{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest",
    "oh-my-openagent@latest"
  ],
  "provider": {
    "ollama-cloud": {
      "models": {
        "gemma4:31b-cloud": {
          "name": "gemma4:31b-cloud",
          "tools": true,
          "thinking": true
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--executable-path",
        "/home/kyiimn/.cache/ms-playwright/chromium-1217/chrome-linux64/chrome",
        "--headless"
      ],
      "enabled": true,
      "environment": {}
    },
    "notebooklm-mcp": {
      "type": "local",
      "enabled": false,
      "command": [
        "uvx",
        "--from",
        "notebooklm-mcp-cli",
        "notebooklm-mcp"
      ]
    }
  }
}
